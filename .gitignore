# ─────────────────────────────────────────────────────────────────────────
# APIN v2 — Plant Pathology Journal
# This repo holds ONLY the source needed to clone and run the app.
# Model weights live in the dxv-404/apin-models HF repo and are pulled at
# Docker-build time; datasets, logs and working notes are not committed.
# ─────────────────────────────────────────────────────────────────────────

# ── Secrets — NEVER commit ───────────────────────────────────────────────
.env
turso_token.png
*.key
*.pem

# ── Python ───────────────────────────────────────────────────────────────
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
.ipynb_checkpoints/

# ── Model weights & signal caches (from dxv-404/apin-models) ─────────────
*.pt
*.pth
*.pkl
*.npz
*.onnx
*.safetensors
models/
scripts/apin/caches/
scripts/apin/results/
scripts/apin/feedback/
scripts/**/*.json
scripts/dinov2_probe/results/
scripts/model3_training/checkpoints/

# ── Datasets (gigabytes — never on GitHub) ───────────────────────────────
data/
data_merged/
data_prep/
cache/
outputs/
old_10class/
Root/
Anthracnose*/
Chili*/
Chilli*/
chilli/
Tomato*/
tomato-village/
tomato_taiwan/
brassica*/
okra-*/
Multicrop*/
LeavesBank*/
ORIGINAL_ALL*/
resized_raw*/
psv_debug/
report_figures/
docs/

# ── Logs, databases, generated artifacts ─────────────────────────────────
*.log
*.jsonl
logs/
wandb/
reports/
feedback.db
*.db
.pipeline_progress.json
pipeline_failures.log

# ── Manifests / large CSVs ───────────────────────────────────────────────
*.csv

# ── Images / figures (not needed at runtime) ─────────────────────────────
*.png
*.svg
*.jpg
*.jpeg
*.gif

# ── Working notes & internal docs (keep only the README + deploy guide) ──
*.md
!/README.md
!/deploy/space_files/README.md
!/scripts/apin_v2/DEPLOYMENT.md

# ── Root-level scratch files ─────────────────────────────────────────────
/*.json
/*.txt
!/requirements.txt
/*.py
!/conftest.py

# ── Agent / IDE / hook config ────────────────────────────────────────────
.claude/
.githooks/
.pre-commit-config.yaml

# ── Deploy build artifacts (regenerated by deploy/ scripts) ──────────────
deploy/apin-models/
deploy/apin-space/

# ── scripts/ — keep the runtime packages, drop build & alt-server code ───
scripts/*.py
!scripts/__init__.py
!scripts/models.py
scripts/model3_server/
scripts/compare_server/

# ── Sub-projects not part of the deployed app ────────────────────────────
tomato_sandbox/
tomato_progress_reports/
training/
agents/
setup/
tools/
templates/
static/
hf_deploy/
hf_space/
