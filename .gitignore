# ─────────────────────────────────────────────────────────────────────────
# APIN v2 — Plant Pathology Journal
# This repo holds ONLY the source needed to clone and run the app.
# Model weights live in the dxv-404/apin-models HF repo and are pulled at
# Docker-build time; datasets, logs and working notes are not committed.
# ─────────────────────────────────────────────────────────────────────────

# ── Secrets — NEVER commit ───────────────────────────────────────────────
.env
turso_token.png
*.key
*.pem

# ── Python ───────────────────────────────────────────────────────────────
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
.ipynb_checkpoints/

# ── Model weights & signal caches (from dxv-404/apin-models) ─────────────
*.pt
*.pth
*.pkl
*.npz
*.onnx
*.safetensors
# 9.N.T31 · IP→city geo DB (DB-IP City Lite, CC-BY) — 124MB, downloaded at
# build/setup like model weights, never committed.
*.mmdb
models/
scripts/apin/caches/
scripts/apin/results/
scripts/apin/feedback/
scripts/**/*.json
# 9.N.T31 · but DO ship the Analytics boundary data (served at runtime by the
# /static/{filename} route; lazy-loaded by the geographic-origin globe/map).
!scripts/apin_v2/geo_world_countries.json
!scripts/apin_v2/geo_world_states.json
!scripts/apin_v2/geo_district_IN.json
scripts/dinov2_probe/results/
scripts/model3_training/checkpoints/

# ── Datasets (gigabytes — never on GitHub) ───────────────────────────────
data/
data_merged/
data_prep/
cache/
outputs/
old_10class/
Root/
Anthracnose*/
Chili*/
Chilli*/
chilli/
Tomato*/
tomato-village/
tomato_taiwan/
brassica*/
okra-*/
Multicrop*/
LeavesBank*/
ORIGINAL_ALL*/
resized_raw*/
psv_debug/
report_figures/
docs/

# ── Logs, databases, generated artifacts ─────────────────────────────────
*.log
*.jsonl
logs/
wandb/
reports/
feedback.db
*.db
.pipeline_progress.json
pipeline_failures.log

# ── Manifests / large CSVs ───────────────────────────────────────────────
*.csv

# ── Images / figures (not needed at runtime) ─────────────────────────────
*.png
*.svg
*.jpg
*.jpeg
*.gif
# ...except the README assets (benchmark charts, screenshots).
!/assets/*.png
!/assets/*.jpg

# ── Working notes & internal docs (keep only the README + deploy guide) ──
*.md
!/README.md
!/deploy/space_files/README.md
!/scripts/apin_v2/DEPLOYMENT.md

# ── Root-level scratch files ─────────────────────────────────────────────
/*.json
/*.txt
!/requirements.txt
/*.py
!/conftest.py

# ── Agent / IDE / hook config ────────────────────────────────────────────
.claude/
.githooks/
.pre-commit-config.yaml

# ── Deploy build artifacts (regenerated by deploy/ scripts) ──────────────
deploy/apin-models/
deploy/apin-space/

# ── scripts/ — keep the runtime packages, drop build & alt-server code ───
scripts/*.py
!scripts/__init__.py
!scripts/models.py
scripts/model3_server/
scripts/compare_server/

# ── Sub-projects not part of the deployed app ────────────────────────────
tomato_sandbox/
tomato_progress_reports/
training/
agents/
setup/
tools/
templates/
static/
hf_deploy/
hf_space/

# ── QA / dev scratch directories ─────────────────────────────────────────
# _qa_tmp/ holds session logs, audit reports, internal probes, and
# regenerable artifacts. EXCEPT the pipeline-atlas JSON data files: the
# /api/pipeline_data/{slug} endpoint reads them at runtime, so they must
# ship with the deploy. Everything else under _qa_tmp/ is excluded.
_qa_tmp/*
!_qa_tmp/_pipeline_atlas_router.json
!_qa_tmp/_pipeline_atlas_tomato.json
!_qa_tmp/_pipeline_atlas_chilli.json
!_qa_tmp/_pipeline_atlas_phase_d.json
!_qa_tmp/_pipeline_atlas_forward_pass.json

# ── tests/ — contains regression baselines + server logs, not unit tests ──
tests/

# ── One-shot QA / build helpers — never invoked at runtime ───────────────
scripts/apin_v2/_glyph_audit.py
scripts/apin_v2/_report_qa_seed.py
scripts/apin_v2/_insert_console_nav_placeholder.py

# ── Deploy helpers and binary samples not needed by the running app ──────
deploy/_apply_rebrand.py
deploy/_sample_report.pdf

# ── Stray scratch artifacts ──────────────────────────────────────────────
pipeline_dump.html
UsersxplodVideos*

# ── Office docs / internal reports — never part of the runnable app ──────
*.docx
*.doc
*.pptx
*.xlsx

# Internal — not shipped to the Space, not needed to clone-and-run
deploy/migrate_localhost_data.py
scripts/apin_v2/DEPLOYMENT.md
